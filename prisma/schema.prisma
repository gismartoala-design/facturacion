generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SELLER
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

enum ReferenceType {
  SALE
  PURCHASE
  MANUAL
}

enum SaleStatus {
  COMPLETED
  CANCELLED
}

enum QuoteStatus {
  OPEN
  CONVERTED
  CANCELLED
}

enum SriInvoiceStatus {
  DRAFT
  AUTHORIZED
  PENDING_SRI
  ERROR
}

model User {
  id           String          @id @default(uuid()) @db.Uuid
  name         String
  email        String          @unique
  passwordHash String
  role         UserRole        @default(SELLER)
  sales        Sale[]
  movements    StockMovement[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model Customer {
  id                 String   @id @default(uuid()) @db.Uuid
  tipoIdentificacion String
  identificacion     String
  razonSocial        String
  direccion          String?
  email              String?
  telefono           String?
  sales              Sale[]
  quotes             Quote[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([tipoIdentificacion, identificacion])
}

model Product {
  id              String          @id @default(uuid()) @db.Uuid
  secuencial      BigInt          @unique @default(autoincrement())
  sku             String?
  nombre          String
  descripcion     String?
  precio          Decimal         @db.Decimal(12, 2)
  tarifaIva       Decimal         @default(15) @db.Decimal(5, 2)
  activo          Boolean         @default(true)
  stockLevel      StockLevel?
  saleItems       SaleItem[]
  quoteItems      QuoteItem[]
  stockMovements  StockMovement[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([sku, activo])
}

model StockLevel {
  id          String   @id @default(uuid()) @db.Uuid
  productId   String   @unique @db.Uuid
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity    Decimal  @default(0) @db.Decimal(14, 3)
  minQuantity Decimal  @default(0) @db.Decimal(14, 3)
  updatedAt   DateTime @updatedAt
}

model StockMovement {
  id            String        @id @default(uuid()) @db.Uuid
  productId     String        @db.Uuid
  product       Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  movementType  MovementType
  quantity      Decimal       @db.Decimal(14, 3)
  referenceType ReferenceType
  referenceId   String?       @db.Uuid
  notes         String?
  createdById   String?       @db.Uuid
  createdBy     User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now())

  @@index([productId, createdAt])
}

model Sale {
  id            String       @id @default(uuid()) @db.Uuid
  saleNumber    BigInt       @unique @default(autoincrement())
  customerId    String       @db.Uuid
  customer      Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  subtotal      Decimal      @db.Decimal(12, 2)
  discountTotal Decimal      @db.Decimal(12, 2)
  taxTotal      Decimal      @db.Decimal(12, 2)
  total         Decimal      @db.Decimal(12, 2)
  status        SaleStatus   @default(COMPLETED)
  createdById   String?      @db.Uuid
  createdBy     User?        @relation(fields: [createdById], references: [id], onDelete: SetNull)
  items         SaleItem[]
  payments      SalePayment[]
  sriInvoice    SriInvoice?
  sourceQuotes  Quote[]      @relation("QuoteConvertedSale")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([createdAt])
}

model Quote {
  id              String      @id @default(uuid()) @db.Uuid
  quoteNumber     BigInt      @unique @default(autoincrement())
  customerId      String      @db.Uuid
  customer        Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  status          QuoteStatus @default(OPEN)
  issuerId        String      @db.Uuid
  fechaEmision    String
  moneda          String      @default("USD")
  formaPago       String
  subtotal        Decimal     @db.Decimal(12, 2)
  discountTotal   Decimal     @db.Decimal(12, 2)
  taxTotal        Decimal     @db.Decimal(12, 2)
  total           Decimal     @db.Decimal(12, 2)
  notes           String?
  convertedSaleId String?     @db.Uuid
  convertedSale   Sale?       @relation("QuoteConvertedSale", fields: [convertedSaleId], references: [id], onDelete: SetNull)
  items           QuoteItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([status, createdAt])
}

model QuoteItem {
  id            String   @id @default(uuid()) @db.Uuid
  quoteId       String   @db.Uuid
  quote         Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId     String   @db.Uuid
  product       Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  cantidad      Decimal  @db.Decimal(14, 3)
  precioUnitario Decimal @db.Decimal(12, 2)
  descuento     Decimal  @default(0) @db.Decimal(12, 2)
  tarifaIva     Decimal  @db.Decimal(5, 2)
  subtotal      Decimal  @db.Decimal(12, 2)
  valorIva      Decimal  @db.Decimal(12, 2)
  total         Decimal  @db.Decimal(12, 2)
}

model SaleItem {
  id            String   @id @default(uuid()) @db.Uuid
  saleId        String   @db.Uuid
  sale          Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId     String   @db.Uuid
  product       Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  cantidad      Decimal  @db.Decimal(14, 3)
  precioUnitario Decimal @db.Decimal(12, 2)
  descuento     Decimal  @default(0) @db.Decimal(12, 2)
  tarifaIva     Decimal  @db.Decimal(5, 2)
  subtotal      Decimal  @db.Decimal(12, 2)
  valorIva      Decimal  @db.Decimal(12, 2)
  total         Decimal  @db.Decimal(12, 2)
}

model SalePayment {
  id          String   @id @default(uuid()) @db.Uuid
  saleId      String   @db.Uuid
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  formaPago   String
  amount      Decimal  @db.Decimal(12, 2)
  plazo       Int      @default(0)
  unidadTiempo String  @default("DIAS")
  createdAt   DateTime @default(now())
}

model SriInvoice {
  id                       String            @id @default(uuid()) @db.Uuid
  saleId                   String            @unique @db.Uuid
  sale                     Sale              @relation(fields: [saleId], references: [id], onDelete: Cascade)
  issuerId                 String            @db.Uuid
  externalInvoiceId        String?           @db.Uuid
  secuencial               String?
  claveAcceso              String?
  status                   SriInvoiceStatus  @default(PENDING_SRI)
  sriReceptionStatus       String?
  sriAuthorizationStatus   String?
  authorizationNumber      String?
  authorizedAt             DateTime?
  retryCount               Int               @default(0)
  lastError                String?
  createRequestPayload     Json
  createResponsePayload    Json?
  authorizeResponsePayload Json?
  documents                SriInvoiceDocument?
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  @@index([status, createdAt])
}

model SriInvoiceDocument {
  id               String     @id @default(uuid()) @db.Uuid
  sriInvoiceId     String     @unique @db.Uuid
  sriInvoice       SriInvoice @relation(fields: [sriInvoiceId], references: [id], onDelete: Cascade)
  xmlSignedPath    String?
  xmlAuthorizedPath String?
  ridePdfPath      String?
  storageProvider  String     @default("local")
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model IntegrationLog {
  id              String   @id @default(uuid()) @db.Uuid
  service         String
  operation       String
  requestPayload  Json
  responsePayload Json?
  httpStatus      Int?
  success         Boolean
  errorMessage    String?
  createdAt       DateTime @default(now())

  @@index([service, operation, createdAt])
}
