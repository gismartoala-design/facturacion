generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SELLER
}

enum BusinessFeatureKey {
  BILLING
  POS
  QUOTES
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

enum ReferenceType {
  SALE
  PURCHASE
  MANUAL
}

enum StockTakingStatus {
  DRAFT
  APPLIED
}

enum SaleStatus {
  COMPLETED
  CANCELLED
}

enum PurchaseStatus {
  POSTED
  VOIDED
}

enum SaleSource {
  POS
  DIRECT_SALE
  QUOTE
}

enum SaleDocumentType {
  NONE
  INVOICE
}

enum SaleDocumentStatus {
  NOT_REQUIRED
  PENDING
  ISSUED
  ERROR
  VOIDED
}

enum PosCashSessionStatus {
  OPEN
  CLOSED
}

enum CashSessionStatus {
  OPEN
  CLOSED
  PENDING_APPROVAL
}

enum CashMovementType {
  OPENING_FLOAT
  SALE_CASH_IN
  MANUAL_IN
  WITHDRAWAL
  REFUND_OUT
  CLOSING_ADJUSTMENT
}

enum CollectionStatus {
  PENDING
  APPLIED
  VOIDED
  REVERSED
  REFUNDED
}

enum CollectionApplicationStatus {
  APPLIED
  REVERSED
  VOIDED
}

enum AccountsReceivableStatus {
  OPEN
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum AccountsPayableStatus {
  OPEN
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum SupplierPaymentStatus {
  APPLIED
  VOIDED
}

enum AccountingEntryStatus {
  DRAFT
  POSTED
  REVERSED
}

enum AccountingAccountGroupKey {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum AccountingAccountNature {
  DEBIT
  CREDIT
}

enum AccountingSourceType {
  SALE
  COLLECTION
  PURCHASE
  SUPPLIER_PAYMENT
  CASH_MOVEMENT
  REFUND
  ADJUSTMENT
}

enum QuoteStatus {
  OPEN
  CONVERTED
  CANCELLED
}

enum SriInvoiceStatus {
  DRAFT
  AUTHORIZED
  PENDING_SRI
  ERROR
}

enum ProductType {
  BIEN
  SERVICIO
}

enum DocumentSeriesType {
  INVOICE
  SALES_NOTE
  CREDIT_NOTE
  DEBIT_NOTE
}

enum TableSessionStatus {
  OPEN
  CLOSED
  MERGED
  TRANSFERRED
}

enum RestaurantOrderChannel {
  DINE_IN
  TAKEOUT
  DELIVERY
}

enum RestaurantOrderStatus {
  OPEN
  IN_PREPARATION
  PARTIALLY_SERVED
  SERVED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum RestaurantOrderItemStatus {
  PENDING
  SENT
  IN_PREPARATION
  READY
  SERVED
  CANCELLED
  BILLED
}

enum KitchenTicketStatus {
  NEW
  IN_PREPARATION
  READY
  SERVED
  CANCELLED
}

enum KitchenTicketItemStatus {
  NEW
  IN_PREPARATION
  READY
  SERVED
  CANCELLED
}

model Business {
  id                 String               @id @default(uuid()) @db.Uuid
  name               String
  legalName          String?
  ruc                String?              @unique
  phone              String?
  email              String?
  address            String?
  slug               String               @unique
  isActive           Boolean              @default(true)
  logoStorageKey     String?
  /// Blueprint canónico del negocio. Fuente de verdad para módulos, edición y capabilities.
  /// Reemplaza al blueprint embebido en BusinessFeature.config (sistema legado).
  blueprintConfig    Json?
  users              User[]
  features           BusinessFeature[]
  taxProfile         TaxProfile?
  documentIssuers    DocumentIssuer[]
  posCashSessions    PosCashSession[]
  posHeldSales       PosHeldSale[]
  cashSessions       CashSession[]
  cashMovements      CashMovement[]
  collections        Collection[]
  receivables        AccountsReceivable[]
  accountingAccounts AccountingAccount[]
  accountingEntries  AccountingEntry[]
  diningAreas        DiningArea[]
  restaurantTables   RestaurantTable[]
  tableSessions      TableSession[]
  restaurantOrders   RestaurantOrder[]
  kitchenStations    KitchenStation[]
  kitchenTickets     KitchenTicket[]
  recipes            Recipe[]
  prepBatches        PrepBatch[]
  stockTakings       StockTaking[]
  suppliers          Supplier[]
  purchases          Purchase[]
  payables           AccountsPayable[]
  supplierPayments   SupplierPayment[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
}

model BusinessFeature {
  id         String             @id @default(uuid()) @db.Uuid
  businessId String             @db.Uuid
  business   Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  key        BusinessFeatureKey
  enabled    Boolean            @default(false)
  config     Json?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@unique([businessId, key])
}

model TaxProfile {
  id                        String   @id @default(uuid()) @db.Uuid
  businessId                String   @unique @db.Uuid
  business                  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  profileType               String   @default("GENERAL")
  requiresElectronicBilling Boolean  @default(true)
  allowsSalesNote           Boolean  @default(false)
  accountingRequired        Boolean  @default(false)
  environment               String   @default("PRUEBAS")
  taxNotes                  String?
  issuerId                  String?  @db.Uuid
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model DocumentIssuer {
  id               String           @id @default(uuid()) @db.Uuid
  businessId       String           @db.Uuid
  business         Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  code             String
  name             String
  legalName        String?
  ruc              String?
  externalIssuerId String?
  environment      String           @default("PRUEBAS")
  active           Boolean          @default(true)
  series           DocumentSeries[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([businessId, code])
  @@index([businessId, active])
}

model DocumentSeries {
  id                String             @id @default(uuid()) @db.Uuid
  issuerId          String             @db.Uuid
  issuer            DocumentIssuer     @relation(fields: [issuerId], references: [id], onDelete: Cascade)
  documentType      DocumentSeriesType
  establishmentCode String
  emissionPointCode String
  nextSequence      Int                @default(1)
  active            Boolean            @default(true)
  saleDocuments     SaleDocument[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([issuerId, documentType, establishmentCode, emissionPointCode])
  @@index([issuerId, documentType, active])
}

model User {
  id                            String                  @id @default(uuid()) @db.Uuid
  businessId                    String                  @db.Uuid
  business                      Business                @relation(fields: [businessId], references: [id], onDelete: Restrict)
  name                          String
  email                         String                  @unique
  passwordHash                  String
  role                          UserRole                @default(SELLER)
  sales                         Sale[]
  movements                     StockMovement[]
  openedCashSessions            PosCashSession[]        @relation("PosCashSessionOpenedBy")
  closedCashSessions            PosCashSession[]        @relation("PosCashSessionClosedBy")
  heldSales                     PosHeldSale[]
  openedCashMgmtSessions        CashSession[]           @relation("CashSessionOpenedBy")
  closedCashMgmtSessions        CashSession[]           @relation("CashSessionClosedBy")
  cashMovements                 CashMovement[]
  registeredCollections         Collection[]            @relation("CollectionRegisteredBy")
  collectionApplications        CollectionApplication[] @relation("CollectionApplicationCreatedBy")
  approvedReconciliations       CashReconciliation[]    @relation("CashReconciliationApprovedBy")
  openedRestaurantTableSessions TableSession[]          @relation("RestaurantTableSessionOpenedBy")
  closedRestaurantTableSessions TableSession[]          @relation("RestaurantTableSessionClosedBy")
  createdRestaurantOrders       RestaurantOrder[]       @relation("RestaurantOrderCreatedBy")
  createdStockTakings           StockTaking[]           @relation("StockTakingCreatedBy")
  appliedStockTakings           StockTaking[]           @relation("StockTakingAppliedBy")
  createdPurchases              Purchase[]              @relation("PurchaseCreatedBy")
  voidedPurchases               Purchase[]              @relation("PurchaseVoidedBy")
  registeredSupplierPayments    SupplierPayment[]       @relation("SupplierPaymentRegisteredBy")
  voidedSupplierPayments        SupplierPayment[]       @relation("SupplierPaymentVoidedBy")
  createdAt                     DateTime                @default(now())
  updatedAt                     DateTime                @updatedAt

  @@index([businessId])
}

model PosCashSession {
  id            String               @id @default(uuid()) @db.Uuid
  businessId    String               @db.Uuid
  business      Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  openedById    String               @db.Uuid
  openedBy      User                 @relation("PosCashSessionOpenedBy", fields: [openedById], references: [id], onDelete: Restrict)
  closedById    String?              @db.Uuid
  closedBy      User?                @relation("PosCashSessionClosedBy", fields: [closedById], references: [id], onDelete: SetNull)
  status        PosCashSessionStatus @default(OPEN)
  openingAmount Decimal              @db.Decimal(12, 2)
  closingAmount Decimal?             @db.Decimal(12, 2)
  notes         String?
  openedAt      DateTime             @default(now())
  closedAt      DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([businessId, status, openedAt])
  @@index([openedById, status])
}

model PosHeldSale {
  id          String   @id @default(uuid()) @db.Uuid
  businessId  String   @db.Uuid
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdById String   @db.Uuid
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  label       String
  payload     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId, createdAt])
  @@index([createdById, updatedAt])
}

model Customer {
  id                 String               @id @default(uuid()) @db.Uuid
  tipoIdentificacion String
  identificacion     String
  razonSocial        String
  direccion          String?
  email              String?
  telefono           String?
  sales              Sale[]
  quotes             Quote[]
  collections        Collection[]
  receivables        AccountsReceivable[]
  restaurantOrders   RestaurantOrder[]
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@unique([tipoIdentificacion, identificacion])
}

model Supplier {
  id                 String   @id @default(uuid()) @db.Uuid
  businessId         String   @db.Uuid
  business           Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  tipoIdentificacion String
  identificacion     String
  razonSocial        String
  nombreComercial    String?
  contactoPrincipal  String?
  email              String?
  telefono           String?
  direccion          String?
  diasCredito        Int      @default(0)
  activo             Boolean  @default(true)
  purchases          Purchase[]
  payables           AccountsPayable[]
  payments           SupplierPayment[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([businessId, tipoIdentificacion, identificacion])
  @@index([businessId, activo, razonSocial])
}

model Purchase {
  id                  String         @id @default(uuid()) @db.Uuid
  purchaseNumber      BigInt         @unique @default(autoincrement())
  businessId          String         @db.Uuid
  business            Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplierId          String         @db.Uuid
  supplier            Supplier       @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  documentType        String
  documentNumber      String
  authorizationNumber String?
  issuedAt            DateTime
  subtotal            Decimal        @db.Decimal(12, 2)
  discountTotal       Decimal        @db.Decimal(12, 2)
  taxTotal            Decimal        @db.Decimal(12, 2)
  total               Decimal        @db.Decimal(12, 2)
  status              PurchaseStatus @default(POSTED)
  notes               String?
  createdById         String?        @db.Uuid
  createdBy           User?          @relation("PurchaseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  voidedAt            DateTime?
  voidedById          String?        @db.Uuid
  voidedBy            User?          @relation("PurchaseVoidedBy", fields: [voidedById], references: [id], onDelete: SetNull)
  voidReason          String?
  payable             AccountsPayable?
  items               PurchaseItem[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@unique([businessId, supplierId, documentType, documentNumber])
  @@index([businessId, status, issuedAt])
  @@index([supplierId, issuedAt])
  @@index([voidedById])
}

model PurchaseItem {
  id         String   @id @default(uuid()) @db.Uuid
  purchaseId String   @db.Uuid
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  String   @db.Uuid
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity   Decimal  @db.Decimal(14, 3)
  unitCost   Decimal  @db.Decimal(12, 4)
  discount   Decimal  @default(0) @db.Decimal(12, 2)
  taxRate    Decimal  @db.Decimal(5, 2)
  subtotal   Decimal  @db.Decimal(12, 2)
  taxTotal   Decimal  @db.Decimal(12, 2)
  total      Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([purchaseId])
  @@index([productId])
}

model AccountsPayable {
  id             String                @id @default(uuid()) @db.Uuid
  businessId     String                @db.Uuid
  business       Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplierId     String                @db.Uuid
  supplier       Supplier              @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  purchaseId     String                @unique @db.Uuid
  purchase       Purchase              @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  documentType   String
  documentNumber String
  currency       String                @default("USD")
  issuedAt       DateTime
  dueAt          DateTime?
  originalAmount Decimal               @db.Decimal(12, 2)
  paidAmount     Decimal               @default(0) @db.Decimal(12, 2)
  pendingAmount  Decimal               @db.Decimal(12, 2)
  status         AccountsPayableStatus @default(OPEN)
  notes          String?
  payments       SupplierPayment[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([businessId, status, issuedAt])
  @@index([supplierId, status, dueAt])
}

model SupplierPayment {
  id                    String                @id @default(uuid()) @db.Uuid
  supplierPaymentNumber BigInt                @unique @default(autoincrement())
  businessId            String                @db.Uuid
  business              Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplierId            String                @db.Uuid
  supplier              Supplier              @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  payableId             String                @db.Uuid
  payable               AccountsPayable       @relation(fields: [payableId], references: [id], onDelete: Restrict)
  amount                Decimal               @db.Decimal(12, 2)
  paymentMethod         String
  status                SupplierPaymentStatus @default(APPLIED)
  externalReference     String?
  notes                 String?
  registeredById        String?               @db.Uuid
  registeredBy          User?                 @relation("SupplierPaymentRegisteredBy", fields: [registeredById], references: [id], onDelete: SetNull)
  paidAt                DateTime              @default(now())
  voidedAt              DateTime?
  voidedById            String?               @db.Uuid
  voidedBy              User?                 @relation("SupplierPaymentVoidedBy", fields: [voidedById], references: [id], onDelete: SetNull)
  voidReason            String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([businessId, paidAt])
  @@index([supplierId, paidAt])
  @@index([payableId, paidAt])
  @@index([status, paidAt])
}

model Product {
  id                    String                @id @default(uuid()) @db.Uuid
  secuencial            BigInt                @unique @default(autoincrement())
  sku                   String?
  codigoBarras          String?
  tipoProducto          ProductType           @default(BIEN)
  nombre                String
  descripcion           String?
  precio                Decimal               @db.Decimal(12, 2)
  tarifaIva             Decimal               @default(15) @db.Decimal(5, 2)
  activo                Boolean               @default(true)
  restaurantVisible     Boolean               @default(false)
  restaurantCategory    String?
  restaurantMenuGroup   String?
  restaurantMenuSortOrder Int?
  restaurantStationCode String?
  allowsModifiers       Boolean               @default(false)
  prepTimeMinutes       Int?
  recipeConsumptionEnabled Boolean            @default(false)
  stockLevel            StockLevel?
  saleItems             SaleItem[]
  quoteItems            QuoteItem[]
  purchaseItems         PurchaseItem[]
  stockMovements        StockMovement[]
  stockTakingItems      StockTakingItem[]
  restaurantOrderItems  RestaurantOrderItem[]
  recipeMenuItems       Recipe[]              @relation("RecipeMenuProduct")
  recipeIngredientItems RecipeIngredient[]    @relation("RecipeIngredientProduct")
  prepBatches           PrepBatch[]
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([sku, activo])
  @@index([codigoBarras, activo])
}

model StockLevel {
  id          String   @id @default(uuid()) @db.Uuid
  productId   String   @unique @db.Uuid
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity    Decimal  @default(0) @db.Decimal(14, 3)
  minQuantity Decimal  @default(0) @db.Decimal(14, 3)
  updatedAt   DateTime @updatedAt
}

model StockMovement {
  id            String        @id @default(uuid()) @db.Uuid
  productId     String        @db.Uuid
  product       Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  movementType  MovementType
  quantity      Decimal       @db.Decimal(14, 3)
  referenceType ReferenceType
  referenceId   String?       @db.Uuid
  notes         String?
  createdById   String?       @db.Uuid
  createdBy     User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now())

  @@index([productId, createdAt])
}

model StockTaking {
  id          String            @id @default(uuid()) @db.Uuid
  takingNumber BigInt           @unique @default(autoincrement())
  businessId  String            @db.Uuid
  business    Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  status      StockTakingStatus @default(DRAFT)
  notes       String?
  createdById String            @db.Uuid
  createdBy   User              @relation("StockTakingCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  appliedById String?           @db.Uuid
  appliedBy   User?             @relation("StockTakingAppliedBy", fields: [appliedById], references: [id], onDelete: SetNull)
  appliedAt   DateTime?
  items       StockTakingItem[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([businessId, status, createdAt])
}

model StockTakingItem {
  id                 String      @id @default(uuid()) @db.Uuid
  stockTakingId      String      @db.Uuid
  stockTaking        StockTaking @relation(fields: [stockTakingId], references: [id], onDelete: Cascade)
  productId          String      @db.Uuid
  product            Product     @relation(fields: [productId], references: [id], onDelete: Restrict)
  systemQuantity     Decimal     @db.Decimal(14, 3)
  countedQuantity    Decimal     @db.Decimal(14, 3)
  differenceQuantity Decimal     @db.Decimal(14, 3)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([stockTakingId])
  @@index([productId])
}

model Sale {
  id                        String                          @id @default(uuid()) @db.Uuid
  saleNumber                BigInt                          @unique @default(autoincrement())
  customerId                String                          @db.Uuid
  customer                  Customer                        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  cashSessionId             String?                         @db.Uuid
  cashSession               CashSession?                    @relation(fields: [cashSessionId], references: [id], onDelete: SetNull)
  restaurantOrderId         String?                         @db.Uuid
  restaurantOrder           RestaurantOrder?                @relation(fields: [restaurantOrderId], references: [id], onDelete: SetNull)
  subtotal                  Decimal                         @db.Decimal(12, 2)
  discountTotal             Decimal                         @db.Decimal(12, 2)
  taxTotal                  Decimal                         @db.Decimal(12, 2)
  total                     Decimal                         @db.Decimal(12, 2)
  status                    SaleStatus                      @default(COMPLETED)
  source                    SaleSource?
  createdById               String?                         @db.Uuid
  createdBy                 User?                           @relation(fields: [createdById], references: [id], onDelete: SetNull)
  items                     SaleItem[]
  payments                  SalePayment[]
  document                  SaleDocument?
  sriInvoice                SriInvoice?
  receivable                AccountsReceivable?
  collectionApplications    CollectionApplication[]
  sourceQuotes              Quote[]                         @relation("QuoteConvertedSale")
  cashMovements             CashMovement[]
  restaurantSettlementItems RestaurantOrderItemSettlement[]
  createdAt                 DateTime                        @default(now())
  updatedAt                 DateTime                        @updatedAt

  @@index([createdAt])
  @@index([cashSessionId, createdAt])
  @@index([restaurantOrderId, createdAt])
}

model Quote {
  id              String      @id @default(uuid()) @db.Uuid
  quoteNumber     BigInt      @unique @default(autoincrement())
  customerId      String      @db.Uuid
  customer        Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  status          QuoteStatus @default(OPEN)
  issuerId        String      @db.Uuid
  fechaEmision    String
  moneda          String      @default("USD")
  formaPago       String
  subtotal        Decimal     @db.Decimal(12, 2)
  discountTotal   Decimal     @db.Decimal(12, 2)
  taxTotal        Decimal     @db.Decimal(12, 2)
  total           Decimal     @db.Decimal(12, 2)
  notes           String?
  convertedSaleId String?     @db.Uuid
  convertedSale   Sale?       @relation("QuoteConvertedSale", fields: [convertedSaleId], references: [id], onDelete: SetNull)
  items           QuoteItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([status, createdAt])
}

model QuoteItem {
  id             String  @id @default(uuid()) @db.Uuid
  quoteId        String  @db.Uuid
  quote          Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  productId      String  @db.Uuid
  product        Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  cantidad       Decimal @db.Decimal(14, 3)
  precioUnitario Decimal @db.Decimal(12, 2)
  descuento      Decimal @default(0) @db.Decimal(12, 2)
  tarifaIva      Decimal @db.Decimal(5, 2)
  subtotal       Decimal @db.Decimal(12, 2)
  valorIva       Decimal @db.Decimal(12, 2)
  total          Decimal @db.Decimal(12, 2)
}

model SaleItem {
  id             String  @id @default(uuid()) @db.Uuid
  saleId         String  @db.Uuid
  sale           Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId      String  @db.Uuid
  product        Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  cantidad       Decimal @db.Decimal(14, 3)
  precioUnitario Decimal @db.Decimal(12, 2)
  descuento      Decimal @default(0) @db.Decimal(12, 2)
  tarifaIva      Decimal @db.Decimal(5, 2)
  subtotal       Decimal @db.Decimal(12, 2)
  valorIva       Decimal @db.Decimal(12, 2)
  total          Decimal @db.Decimal(12, 2)
}

model SalePayment {
  id           String   @id @default(uuid()) @db.Uuid
  saleId       String   @db.Uuid
  sale         Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  formaPago    String
  amount       Decimal  @db.Decimal(12, 2)
  plazo        Int      @default(0)
  unidadTiempo String   @default("DIAS")
  createdAt    DateTime @default(now())
}

model SaleDocument {
  id                String             @id @default(uuid()) @db.Uuid
  saleId            String             @unique @db.Uuid
  sale              Sale               @relation(fields: [saleId], references: [id], onDelete: Cascade)
  type              SaleDocumentType
  status            SaleDocumentStatus
  issuerId          String?            @db.Uuid
  documentSeriesId  String?            @db.Uuid
  documentSeries    DocumentSeries?    @relation(fields: [documentSeriesId], references: [id], onDelete: SetNull)
  establishmentCode String?
  emissionPointCode String?
  sequenceNumber    Int?
  fullNumber        String?
  issuedAt          DateTime?
  metadata          Json?
  sriInvoiceId      String?            @unique @db.Uuid
  sriInvoice        SriInvoice?        @relation(fields: [sriInvoiceId], references: [id], onDelete: SetNull)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([documentSeriesId, sequenceNumber])
  @@index([type, status, createdAt])
}

model SriInvoice {
  id                       String              @id @default(uuid()) @db.Uuid
  saleId                   String              @unique @db.Uuid
  sale                     Sale                @relation(fields: [saleId], references: [id], onDelete: Cascade)
  saleDocument             SaleDocument?
  issuerId                 String              @db.Uuid
  externalInvoiceId        String?             @db.Uuid
  secuencial               String?
  claveAcceso              String?
  status                   SriInvoiceStatus    @default(PENDING_SRI)
  sriReceptionStatus       String?
  sriAuthorizationStatus   String?
  authorizationNumber      String?
  authorizedAt             DateTime?
  retryCount               Int                 @default(0)
  lastError                String?
  createRequestPayload     Json
  createResponsePayload    Json?
  authorizeResponsePayload Json?
  documents                SriInvoiceDocument?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  @@index([status, createdAt])
}

model SriInvoiceDocument {
  id                String     @id @default(uuid()) @db.Uuid
  sriInvoiceId      String     @unique @db.Uuid
  sriInvoice        SriInvoice @relation(fields: [sriInvoiceId], references: [id], onDelete: Cascade)
  xmlSignedPath     String?
  xmlAuthorizedPath String?
  ridePdfPath       String?
  storageProvider   String     @default("local")
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

model IntegrationLog {
  id              String   @id @default(uuid()) @db.Uuid
  service         String
  operation       String
  requestPayload  Json
  responsePayload Json?
  httpStatus      Int?
  success         Boolean
  errorMessage    String?
  createdAt       DateTime @default(now())

  @@index([service, operation, createdAt])
}

// ============================================================
// CASH MANAGEMENT
// ============================================================

model CashSession {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @db.Uuid
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  openedById String  @db.Uuid
  openedBy   User    @relation("CashSessionOpenedBy", fields: [openedById], references: [id], onDelete: Restrict)
  closedById String? @db.Uuid
  closedBy   User?   @relation("CashSessionClosedBy", fields: [closedById], references: [id], onDelete: SetNull)

  status          CashSessionStatus @default(OPEN)
  openingAmount   Decimal           @db.Decimal(12, 2)
  declaredClosing Decimal?          @db.Decimal(12, 2)
  expectedClosing Decimal?          @db.Decimal(12, 2)
  difference      Decimal?          @db.Decimal(12, 2)

  notes     String?
  openedAt  DateTime  @default(now())
  closedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  movements      CashMovement[]
  sales          Sale[]
  collections    Collection[]
  reconciliation CashReconciliation?
  counts         CashCount[]

  @@index([businessId, status, openedAt])
  @@index([openedById, status])
}

model CashMovement {
  id         String   @id @default(uuid()) @db.Uuid
  businessId String   @db.Uuid
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  sessionId String      @db.Uuid
  session   CashSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  type   CashMovementType
  amount Decimal          @db.Decimal(12, 2)

  saleId String? @db.Uuid
  sale   Sale?   @relation(fields: [saleId], references: [id], onDelete: SetNull)

  description String?
  createdById String   @db.Uuid
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())

  @@index([sessionId, type])
  @@index([businessId, createdAt])
}

model Collection {
  id                         String           @id @default(uuid()) @db.Uuid
  businessId                 String           @db.Uuid
  business                   Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId                 String           @db.Uuid
  customer                   Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  cashSessionId              String?          @db.Uuid
  cashSession                CashSession?     @relation(fields: [cashSessionId], references: [id], onDelete: SetNull)
  amount                     Decimal          @db.Decimal(12, 2)
  paymentMethod              String
  status                     CollectionStatus @default(APPLIED)
  affectsCashDrawer          Boolean          @default(false)
  requiresBankReconciliation Boolean          @default(false)
  externalReference          String?
  notes                      String?
  registeredById             String?          @db.Uuid
  registeredBy               User?            @relation("CollectionRegisteredBy", fields: [registeredById], references: [id], onDelete: SetNull)
  collectedAt                DateTime         @default(now())
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt

  applications CollectionApplication[]

  @@index([businessId, collectedAt])
  @@index([cashSessionId, collectedAt])
  @@index([customerId, collectedAt])
  @@index([status, collectedAt])
}

model CollectionApplication {
  id            String                      @id @default(uuid()) @db.Uuid
  collectionId  String                      @db.Uuid
  collection    Collection                  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  saleId        String?                     @db.Uuid
  sale          Sale?                       @relation(fields: [saleId], references: [id], onDelete: SetNull)
  receivableId  String?                     @db.Uuid
  receivable    AccountsReceivable?         @relation(fields: [receivableId], references: [id], onDelete: SetNull)
  appliedAmount Decimal                     @db.Decimal(12, 2)
  status        CollectionApplicationStatus @default(APPLIED)
  notes         String?
  createdById   String?                     @db.Uuid
  createdBy     User?                       @relation("CollectionApplicationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  appliedAt     DateTime                    @default(now())
  createdAt     DateTime                    @default(now())

  @@index([collectionId, appliedAt])
  @@index([saleId, appliedAt])
  @@index([receivableId, appliedAt])
}

model AccountsReceivable {
  id             String                   @id @default(uuid()) @db.Uuid
  businessId     String                   @db.Uuid
  business       Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customerId     String                   @db.Uuid
  customer       Customer                 @relation(fields: [customerId], references: [id], onDelete: Restrict)
  saleId         String?                  @unique @db.Uuid
  sale           Sale?                    @relation(fields: [saleId], references: [id], onDelete: SetNull)
  documentType   String
  documentId     String?                  @db.Uuid
  currency       String                   @default("USD")
  issuedAt       DateTime
  dueAt          DateTime?
  originalAmount Decimal                  @db.Decimal(12, 2)
  appliedAmount  Decimal                  @default(0) @db.Decimal(12, 2)
  pendingAmount  Decimal                  @db.Decimal(12, 2)
  status         AccountsReceivableStatus @default(OPEN)
  notes          String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  applications CollectionApplication[]

  @@index([businessId, status, issuedAt])
  @@index([customerId, status, dueAt])
}

model AccountingAccount {
  id              String                    @id @default(uuid()) @db.Uuid
  businessId      String                    @db.Uuid
  business        Business                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  code            String
  name            String
  groupKey        AccountingAccountGroupKey
  defaultNature   AccountingAccountNature
  parentId        String?                   @db.Uuid
  parent          AccountingAccount?        @relation("AccountingAccountParent", fields: [parentId], references: [id], onDelete: SetNull)
  children        AccountingAccount[]       @relation("AccountingAccountParent")
  level           Int                       @default(1)
  acceptsPostings Boolean                   @default(true)
  system          Boolean                   @default(false)
  active          Boolean                   @default(true)
  description     String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  @@unique([businessId, code])
  @@index([businessId, groupKey, active])
  @@index([parentId])
}

model AccountingEntry {
  id          String                @id @default(uuid()) @db.Uuid
  businessId  String                @db.Uuid
  business    Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  entryNumber Int?
  sourceType  AccountingSourceType
  sourceId    String                @db.Uuid
  status      AccountingEntryStatus @default(DRAFT)
  postedAt    DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  lines AccountingEntryLine[]

  @@unique([businessId, entryNumber])
  @@index([businessId, sourceType, sourceId])
  @@index([status, createdAt])
}

model AccountingEntryLine {
  id          String          @id @default(uuid()) @db.Uuid
  entryId     String          @db.Uuid
  entry       AccountingEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  accountCode String
  debit       Decimal         @default(0) @db.Decimal(12, 2)
  credit      Decimal         @default(0) @db.Decimal(12, 2)
  memo        String?
  createdAt   DateTime        @default(now())

  @@index([entryId])
  @@index([accountCode])
}

model CashCount {
  id        String      @id @default(uuid()) @db.Uuid
  sessionId String      @db.Uuid
  session   CashSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  denomination Decimal @db.Decimal(10, 2)
  quantity     Int
  subtotal     Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@index([sessionId])
}

model CashReconciliation {
  id        String      @id @default(uuid()) @db.Uuid
  sessionId String      @unique @db.Uuid
  session   CashSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  expectedAmount Decimal @db.Decimal(12, 2)
  declaredAmount Decimal @db.Decimal(12, 2)
  difference     Decimal @db.Decimal(12, 2)

  reason       String?
  approvedById String?   @db.Uuid
  approvedBy   User?     @relation("CashReconciliationApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt   DateTime?

  createdAt DateTime @default(now())

  @@index([sessionId])
}

model DiningArea {
  id         String            @id @default(uuid()) @db.Uuid
  businessId String            @db.Uuid
  business   Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  code       String
  name       String
  sortOrder  Int               @default(0)
  active     Boolean           @default(true)
  tables     RestaurantTable[]
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@unique([businessId, code])
  @@index([businessId, active, sortOrder])
}

model RestaurantTable {
  id           String         @id @default(uuid()) @db.Uuid
  businessId   String         @db.Uuid
  business     Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  diningAreaId String?        @db.Uuid
  diningArea   DiningArea?    @relation(fields: [diningAreaId], references: [id], onDelete: SetNull)
  code         String
  name         String
  capacity     Int            @default(4)
  active       Boolean        @default(true)
  sessions     TableSession[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([businessId, code])
  @@index([businessId, active, diningAreaId])
}

model TableSession {
  id         String             @id @default(uuid()) @db.Uuid
  businessId String             @db.Uuid
  business   Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  tableId    String             @db.Uuid
  table      RestaurantTable    @relation(fields: [tableId], references: [id], onDelete: Restrict)
  openedById String             @db.Uuid
  openedBy   User               @relation("RestaurantTableSessionOpenedBy", fields: [openedById], references: [id], onDelete: Restrict)
  closedById String?            @db.Uuid
  closedBy   User?              @relation("RestaurantTableSessionClosedBy", fields: [closedById], references: [id], onDelete: SetNull)
  status     TableSessionStatus @default(OPEN)
  guestCount Int                @default(1)
  notes      String?
  openedAt   DateTime           @default(now())
  closedAt   DateTime?
  orders     RestaurantOrder[]
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([businessId, status, openedAt])
  @@index([tableId, status, openedAt])
}

model RestaurantOrder {
  id                 String                 @id @default(uuid()) @db.Uuid
  businessId         String                 @db.Uuid
  business           Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  tableSessionId     String?                @db.Uuid
  tableSession       TableSession?          @relation(fields: [tableSessionId], references: [id], onDelete: SetNull)
  customerId         String?                @db.Uuid
  customer           Customer?              @relation(fields: [customerId], references: [id], onDelete: SetNull)
  channel            RestaurantOrderChannel
  status             RestaurantOrderStatus  @default(OPEN)
  guestCount         Int?
  customerName       String?
  customerPhone      String?
  deliveryAddress    String?
  deliveryReference  String?
  assignedDriverName String?
  dispatchedAt       DateTime?
  deliveredAt        DateTime?
  notes              String?
  createdById        String?                @db.Uuid
  createdBy          User?                  @relation("RestaurantOrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items              RestaurantOrderItem[]
  kitchenTickets     KitchenTicket[]
  sales              Sale[]
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([businessId, status, createdAt])
  @@index([tableSessionId, status])
  @@index([channel, status, createdAt])
}

model RestaurantOrderItem {
  id                    String                          @id @default(uuid()) @db.Uuid
  orderId               String                          @db.Uuid
  order                 RestaurantOrder                 @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId             String                          @db.Uuid
  product               Product                         @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity              Decimal                         @db.Decimal(14, 3)
  billedQuantity        Decimal                         @default(0) @db.Decimal(14, 3)
  cancelledQuantity     Decimal                         @default(0) @db.Decimal(14, 3)
  precioUnitario        Decimal                         @db.Decimal(12, 2)
  descuento             Decimal                         @default(0) @db.Decimal(12, 2)
  tarifaIva             Decimal                         @db.Decimal(5, 2)
  notes                 String?
  status                RestaurantOrderItemStatus       @default(PENDING)
  sentAt                DateTime?
  preparedAt            DateTime?
  readyAt               DateTime?
  servedAt              DateTime?
  modifiers             OrderItemModifier[]
  kitchenTicketItems    KitchenTicketItem[]
  settlements           RestaurantOrderItemSettlement[]
  prepBatchConsumptions PrepBatchConsumption[]
  createdAt             DateTime                        @default(now())
  updatedAt             DateTime                        @updatedAt

  @@index([orderId, status, createdAt])
  @@index([productId, status])
}

model OrderItemModifier {
  id          String              @id @default(uuid()) @db.Uuid
  orderItemId String              @db.Uuid
  orderItem   RestaurantOrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  name        String
  priceDelta  Decimal             @default(0) @db.Decimal(12, 2)
  createdAt   DateTime            @default(now())
}

model KitchenStation {
  id         String          @id @default(uuid()) @db.Uuid
  businessId String          @db.Uuid
  business   Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  code       String
  name       String
  sortOrder  Int             @default(0)
  active     Boolean         @default(true)
  tickets    KitchenTicket[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([businessId, code])
  @@index([businessId, active, sortOrder])
}

model KitchenTicket {
  id          String              @id @default(uuid()) @db.Uuid
  businessId  String              @db.Uuid
  business    Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  orderId     String              @db.Uuid
  order       RestaurantOrder     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stationId   String?             @db.Uuid
  station     KitchenStation?     @relation(fields: [stationId], references: [id], onDelete: SetNull)
  stationCode String
  status      KitchenTicketStatus @default(NEW)
  printedAt   DateTime?
  startedAt   DateTime?
  readyAt     DateTime?
  servedAt    DateTime?
  notes       String?
  items       KitchenTicketItem[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([businessId, status, createdAt])
  @@index([orderId, status, createdAt])
}

model KitchenTicketItem {
  id          String                  @id @default(uuid()) @db.Uuid
  ticketId    String                  @db.Uuid
  ticket      KitchenTicket           @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  orderItemId String                  @db.Uuid
  orderItem   RestaurantOrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  quantity    Decimal                 @db.Decimal(14, 3)
  status      KitchenTicketItemStatus @default(NEW)
  startedAt   DateTime?
  readyAt     DateTime?
  servedAt    DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([ticketId, status, createdAt])
  @@index([orderItemId, status, createdAt])
}

model Recipe {
  id          String             @id @default(uuid()) @db.Uuid
  businessId  String             @db.Uuid
  business    Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  productId   String             @db.Uuid
  product     Product            @relation("RecipeMenuProduct", fields: [productId], references: [id], onDelete: Cascade)
  notes       String?
  ingredients RecipeIngredient[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@unique([businessId, productId])
}

model RecipeIngredient {
  id             String   @id @default(uuid()) @db.Uuid
  recipeId       String   @db.Uuid
  recipe         Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  productId      String   @db.Uuid
  product        Product  @relation("RecipeIngredientProduct", fields: [productId], references: [id], onDelete: Restrict)
  quantity       Decimal  @db.Decimal(14, 3)
  usePrepBatches Boolean  @default(false)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([recipeId])
  @@index([productId])
}

model PrepBatch {
  id                String                 @id @default(uuid()) @db.Uuid
  businessId        String                 @db.Uuid
  business          Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  productId         String                 @db.Uuid
  product           Product                @relation(fields: [productId], references: [id], onDelete: Restrict)
  label             String
  producedQuantity  Decimal                @db.Decimal(14, 3)
  availableQuantity Decimal                @db.Decimal(14, 3)
  notes             String?
  producedAt        DateTime               @default(now())
  expiresAt         DateTime?
  consumptions      PrepBatchConsumption[]
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([businessId, productId, producedAt])
}

model PrepBatchConsumption {
  id                    String               @id @default(uuid()) @db.Uuid
  prepBatchId           String               @db.Uuid
  prepBatch             PrepBatch            @relation(fields: [prepBatchId], references: [id], onDelete: Cascade)
  restaurantOrderItemId String?              @db.Uuid
  restaurantOrderItem   RestaurantOrderItem? @relation(fields: [restaurantOrderItemId], references: [id], onDelete: SetNull)
  quantity              Decimal              @db.Decimal(14, 3)
  createdAt             DateTime             @default(now())

  @@index([prepBatchId, createdAt])
  @@index([restaurantOrderItemId, createdAt])
}

model RestaurantOrderItemSettlement {
  id                    String              @id @default(uuid()) @db.Uuid
  restaurantOrderItemId String              @db.Uuid
  restaurantOrderItem   RestaurantOrderItem @relation(fields: [restaurantOrderItemId], references: [id], onDelete: Cascade)
  saleId                String              @db.Uuid
  sale                  Sale                @relation(fields: [saleId], references: [id], onDelete: Cascade)
  quantity              Decimal             @db.Decimal(14, 3)
  subtotal              Decimal             @db.Decimal(12, 2)
  taxTotal              Decimal             @db.Decimal(12, 2)
  total                 Decimal             @db.Decimal(12, 2)
  createdAt             DateTime            @default(now())

  @@index([saleId, createdAt])
  @@index([restaurantOrderItemId, createdAt])
}
